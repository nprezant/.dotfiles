<?xml version="1.0" ?>
<labwc_config>
    <keyboard>
        <default />
        <keybind key="W-S-d"><action name="ToggleShowDesktop" /></keybind>
        <keybind key="W-d"><action name="Execute" command="rofi -show drun" /></keybind>
        <keybind key="W-1"><action name="GoToDesktop" to="1" /></keybind>
        <keybind key="W-2"><action name="GoToDesktop" to="2" /></keybind>
        <keybind key="W-3"><action name="GoToDesktop" to="3" /></keybind>
        <keybind key="W-4"><action name="GoToDesktop" to="4" /></keybind>
        <keybind key="W-5"><action name="GoToDesktop" to="5" /></keybind>
        <keybind key="W-S-Left"><action name="GoToDesktop" to="left" /></keybind>
        <keybind key="W-S-Right"><action name="GoToDesktop" to="right" /></keybind>
        <keybind key="A-q"><action name="Close" to="right" /></keybind>
        <keybind key="W-S-q"><action name="Close" to="right" /></keybind>
        <keybind key="W-z"><action name="ToggleMagnify" /></keybind>
        <keybind key="W-x"><action name="ZoomIn" /></keybind>
        <keybind key="W-l"><action name="Execute" command="sh -c 'swaylock'" /></keybind>
        <keybind key="W-S-x"><action name="ZoomOut" /></keybind>
        <keybind key="W-S-s"><action name="Execute" command="sh -c 'grim -g &quot;$(slurp)&quot; - | swappy -f -'" /></keybind>
        <keybind key="W-v"><action name="Execute" command="sh -c 'cliphist list | rofi -dmenu | cliphist decode | wl-copy'" /></keybind>
    </keyboard>
    <desktops number="5" prefix="ws" />
    <context name="All">
      <mousebind direction="W-Up" action="Scroll">
        <action name="GoToDesktop" to="right"/>
      </mousebind>
      <mousebind direction="W-Down" action="Scroll">
        <action name="GoToDesktop" to="left"/>
      </mousebind>
    </context>
</labwc_config>
