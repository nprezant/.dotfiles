# background
swaybg -i ~/pictures/wallpapers/duck.jpg &

# bar
waybar &

# lock screen after idle
swayidle -w \
    timeout 300 'swaylock -f -c 000000' \
    timeout 600 'wlopm --off \*' \
    resume 'wlopm --on \*' \
    before-sleep 'swaylock -f -c 000000' >/dev/null 2>&1 &

# clipboard history
wl-paste --watch cliphist store &
